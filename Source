		RunService.RenderStepped:Connect(function()
			if resizing and resizeInput then
				local d = resizeInput.Position - resizeStart
				local nW = math.clamp(startSize.X + d.X, 480, self.Gui.AbsoluteSize.X - 20)
				local nH = math.clamp(startSize.Y + d.Y, 300, self.Gui.AbsoluteSize.Y - 20)
				TweenService:Create(Wrapper, TweenInfo.new(0.06, Enum.EasingStyle.Sine), {Size = UDim2.new(0, nW, 0, nH)}):Play()
			end
		end)
	end

