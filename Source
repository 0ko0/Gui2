		end)
		self.Top.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end end)
		RunService.RenderStepped:Connect(function()
			if dragging and dragInput then
				local d = dragInput.Position - dragStart
				local sz, gui = Wrapper.AbsoluteSize, self.Gui.AbsoluteSize
				local tgtX = math.clamp(startPos.X.Offset + d.X + (startPos.X.Scale * gui.X), sz.X/2, gui.X - sz.X/2)
				local tgtY = math.clamp(startPos.Y.Offset + d.Y + (startPos.Y.Scale * gui.Y), sz.Y/2, gui.Y - sz.Y/2)
				TweenService:Create(Wrapper, TweenInfo.new(0.06, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Position = UDim2.fromOffset(tgtX, tgtY)}):Play()
