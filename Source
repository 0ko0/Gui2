	-- [ ANIMATION BẬT/TẮT UI (Mượt mà chuẩn Apple) ]
	local IsOpen = true
	local function ToggleUI(state)
		IsOpen = state
		if IsOpen then
			Wrapper.Visible = true
			FloatingBtn.Visible = false
			-- Hiệu ứng nảy nhẹ (Back)
			TweenService:Create(self.Main:FindFirstChild("Scale"), TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
			TweenService:Create(self.Main, TweenInfo.new(0.3, Enum.EasingStyle.Sine), {BackgroundTransparency = 0.05}):Play()
		else
			-- Hiệu ứng thu nhỏ mượt mà
			local hideTween = TweenService:Create(self.Main:FindFirstChild("Scale"), TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Scale = 0.85})
			TweenService:Create(self.Main, TweenInfo.new(0.3, Enum.EasingStyle.Sine), {BackgroundTransparency = 1}):Play()
			hideTween:Play()
			hideTween.Completed:Connect(function()
				if not IsOpen then 
					Wrapper.Visible = false 
					FloatingBtn.Visible = true 
				end
			end)
		end
	end

	CloseBtn.MouseButton1Click:Connect(function() ToggleUI(false) end)
	MinimizeBtn.MouseButton1Click:Connect(function() ToggleUI(false) end)
	FloatingBtn.MouseButton1Click:Connect(function() ToggleUI(true) end)

	UIS.InputBegan:Connect(function(input, gpe)
		if not gpe and input.KeyCode == (Library.ToggleKey or Enum.KeyCode.RightShift) then
			ToggleUI(not IsOpen)
		end
	end)

	-- [ THUẬT TOÁN KÉO THẢ TỐI ƯU (Chống văng màn hình cho Mobile) ]
	do
		local dragging, dragInput, dragStart, startPos
		self.Top.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				dragStart = input.Position
				startPos = Wrapper.Position
				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then dragging = false end
				end)
			end
		end)
		self.Top.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
				dragInput = input
			end
		end)
		RunService.RenderStepped:Connect(function()
			if dragging and dragInput then
				local delta = dragInput.Position - dragStart
				local newPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
				
				-- Screen Clamping (Giữ UI luôn ở trong màn hình)
				local screenSize = self.Gui.AbsoluteSize
				local uiSize = Wrapper.AbsoluteSize
				local minX = uiSize.X / 2
				local maxX = screenSize.X - (uiSize.X / 2)
				local minY = uiSize.Y / 2
				local maxY = screenSize.Y - (uiSize.Y / 2)

				local clampedX = math.clamp(newPos.X.Offset + (newPos.X.Scale * screenSize.X), minX, maxX)
				local clampedY = math.clamp(newPos.Y.Offset + (newPos.Y.Scale * screenSize.Y), minY, maxY)

				TweenService:Create(Wrapper, TweenInfo.new(0.08, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
					Position = UDim2.fromOffset(clampedX, clampedY)
				}):Play()
			end
		end)
	end

	-- [ THUẬT TOÁN RESIZE TỐI ƯU ]
	do
		local resizing, resizeInput, resizeStart, startSize
		ResizeGrip.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				resizing = true
				resizeStart = input.Position
				startSize = Wrapper.AbsoluteSize
				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then resizing = false end
				end)
			end
		end)
		ResizeGrip.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
				resizeInput = input
			end
		end)
		RunService.RenderStepped:Connect(function()
			if resizing and resizeInput then
				local delta = resizeInput.Position - resizeStart
				local screenSize = self.Gui.AbsoluteSize
				-- Giới hạn kích thước không vượt quá màn hình thiết bị
				local newWidth = math.clamp(startSize.X + delta.X, 450, math.min(1000, screenSize.X - 20))
				local newHeight = math.clamp(startSize.Y + delta.Y, 300, math.min(700, screenSize.Y - 20))
				
				TweenService:Create(Wrapper, TweenInfo.new(0.08, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
					Size = UDim2.new(0, newWidth, 0, newHeight)
				}):Play()
			end
		end)
	end

