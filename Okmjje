				ZIndex = 0,
				Parent = Knob
			}, { Create("UICorner", {CornerRadius = UDim.new(1, 0)}) })

			local function SetSlider(value, doCallback)
				local clampedValue = math.clamp(value, min, max)
				local finalValue, formattedText = FormatValue(clampedValue)
				currentValue = finalValue

				local percentage = (finalValue - min) / (max - min)
				
				TweenService:Create(Fill, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.fromScale(percentage, 1)}):Play()
				TweenService:Create(Knob, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.fromScale(percentage, 0.5)}):Play()
				
				if not ValueInput:IsFocused() then
					ValueInput.Text = formattedText
				end

				if doCallback then
					task.spawn(callback, finalValue)
				end
			end

			local function UpdateFromInput(input)
				local trackPos = Track.AbsolutePosition.X
				local trackSize = Track.AbsoluteSize.X
				local inputPos = input.Position.X
				
				local percentage = math.clamp((inputPos - trackPos) / trackSize, 0, 1)
				local rawValue = min + (max - min) * percentage
				SetSlider(rawValue, true)
			end

			TrackArea.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					UpdateFromInput(input)
					
					TweenService:Create(Knob, TweenInfo.new(0.2), {Size = UDim2.fromOffset(14, 14)}):Play()
					TweenService:Create(KnobGlow, TweenInfo.new(0.2), {Size = UDim2.fromOffset(28, 28), BackgroundTransparency = 0.6}):Play()
				end
			end)

			UIS.InputChanged:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					UpdateFromInput(input)
				end
			end)

			UIS.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					if dragging then
						dragging = false
						
						TweenService:Create(Knob, TweenInfo.new(0.2), {Size = UDim2.fromOffset(10, 10)}):Play()
						TweenService:Create(KnobGlow, TweenInfo.new(0.2), {Size = UDim2.fromOffset(0, 0), BackgroundTransparency = 1}):Play()
					end
				end
			end)

			TrackArea.MouseEnter:Connect(function()
				if not dragging then
					TweenService:Create(KnobGlow, TweenInfo.new(0.2), {Size = UDim2.fromOffset(20, 20), BackgroundTransparency = 0.8}):Play()
				end
			end)
			TrackArea.MouseLeave:Connect(function()
				if not dragging then
					TweenService:Create(KnobGlow, TweenInfo.new(0.2), {Size = UDim2.fromOffset(0, 0), BackgroundTransparency = 1}):Play()
				end
			end)

			ValueInput.Focused:Connect(function()
				TweenService:Create(ValueInputHolder.Stroke, TweenInfo.new(0.3), {Color = Color3.fromRGB(80, 150, 255)}):Play()
				ValueInput.Text = tostring(currentValue)
			end)

			ValueInput.FocusLost:Connect(function()
				TweenService:Create(ValueInputHolder.Stroke, TweenInfo.new(0.3), {Color = Color3.fromRGB(45, 45, 60)}):Play()
				
				local num = tonumber(string.match(ValueInput.Text, "-?%d+%.?%d*"))
				if num then
					SetSlider(num, true)
				else
					
					SetSlider(currentValue, false)
				end
			end)

			local SliderAPI = {}
			function SliderAPI:SetValue(val)
				SetSlider(val, true)
			end
			function SliderAPI:GetValue()
				return currentValue
			end

			return SliderAPI
		end

