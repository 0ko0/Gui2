				PaddingBottom = UDim.new(0, 10)
			})
		})

		local UIListLayout = Page:FindFirstChildOfClass("UIListLayout")

		local function UpdateCanvasSize()
			Page.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 25)
		end
		UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdateCanvasSize)
		task.spawn(UpdateCanvasSize)

		TabBg:SetAttribute("Active", false)

		TabBtn.MouseEnter:Connect(function()
			if not TabBg:GetAttribute("Active") then
				TweenService:Create(TabBtn, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {TextColor3 = Color3.fromRGB(200, 200, 220)}):Play()
