			TweenService:Create(TabBtn, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()

			for _, p in ipairs(self.Pages:GetChildren()) do 
				if p:IsA("ScrollingFrame") then p.Visible = false end 
			end
			
			Page.Position = UDim2.new(0, 0, 0, 15) 
			Page.Visible = true
			TweenService:Create(Page, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
				Position = UDim2.new(0, 0, 0, 0)
			}):Play()
