				Text = formatKeyName(currentKey),
				Font = Enum.Font.GothamBold,
				TextSize = 12,
				TextColor3 = Color3.fromRGB(255, 255, 255),
				BackgroundTransparency = 1,
				Size = UDim2.fromScale(1, 1),
				ZIndex = 3,
				Parent = BindDisplay
			})

			local Hit = Create("TextButton", {Text = "", BackgroundTransparency = 1, Size = UDim2.fromScale(1, 1), ZIndex = 5, Parent = BindDisplay})

			ModeBtn.MouseButton1Click:Connect(function()
				currentMode = currentMode == "Toggle" and "Hold" or "Toggle"
				ModeBtn.Text = currentMode
				TweenService:Create(ModeBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(40, 40, 55)}):Play()
				task.delay(0.2, function()
					TweenService:Create(ModeBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(30, 30, 40)}):Play()
				end)
			end)

			Hit.MouseButton1Click:Connect(function()
				if isListening then return end
				isListening = true
				BindText.Text = "..."
				
				TweenService:Create(BindDisplay, TweenInfo.new(0.1), {Size = UDim2.fromOffset(56, 24), Position = UDim2.new(1, -68, 0.5, -12)}):Play()
				task.delay(0.1, function()
					TweenService:Create(BindDisplay, TweenInfo.new(0.1), {Size = UDim2.fromOffset(60, 26), Position = UDim2.new(1, -70, 0.5, -13)}):Play()
				end)

				local stroke = BindDisplay:FindFirstChild("Stroke")
				pulseTween = TweenService:Create(stroke, TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {Color = Color3.fromRGB(80, 150, 255), Thickness = 2})
				pulseTween:Play()
			end)

			local inputConnection
			inputConnection = UIS.InputBegan:Connect(function(input, gpe)
				
				if isListening then
					local key = input.KeyCode
					local inputType = input.UserInputType

					if key == Enum.KeyCode.Backspace or key == Enum.KeyCode.Delete then
						currentKey = Enum.KeyCode.Unknown
						BindText.Text = "None"
						isListening = false
				
					elseif (key ~= Enum.KeyCode.Unknown and not table.find(blacklist, key)) or (inputType.Name:find("MouseButton")) then
						currentKey = key ~= Enum.KeyCode.Unknown and key or inputType
						BindText.Text = formatKeyName(key, inputType)
						isListening = false
					end

					if not isListening then
						if pulseTween then pulseTween:Cancel() end
						local stroke = BindDisplay:FindFirstChild("Stroke")
						TweenService:Create(stroke, TweenInfo.new(0.3), {Color = Color3.fromRGB(60, 60, 80), Thickness = 1}):Play()
						
						TweenService:Create(BindDisplay, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(40, 200, 100)}):Play()
						task.delay(0.2, function()
							TweenService:Create(BindDisplay, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(25, 25, 35)}):Play()
						end)
						
						onChange(currentKey)
					end
					return
				end

				if not gpe and not isListening then
					local isMatch = false
					if typeof(currentKey) == "EnumItem" then
						if currentKey.EnumType == Enum.KeyCode and input.KeyCode == currentKey then isMatch = true end
						if currentKey.EnumType == Enum.UserInputType and input.UserInputType == currentKey then isMatch = true end
					end

					if isMatch then
						if currentMode == "Toggle" then
							isActive = not isActive
							callback(isActive)
						elseif currentMode == "Hold" then
							isActive = true
							callback(isActive)
						end
						
						TweenService:Create(BindDisplay, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(80, 150, 255)}):Play()
					end
				end
			end)

			UIS.InputEnded:Connect(function(input, gpe)
				if not gpe and not isListening and currentMode == "Hold" then
					local isMatch = false
					if typeof(currentKey) == "EnumItem" then
						if currentKey.EnumType == Enum.KeyCode and input.KeyCode == currentKey then isMatch = true end
						if currentKey.EnumType == Enum.UserInputType and input.UserInputType == currentKey then isMatch = true end
					end

					if isMatch then
						isActive = false
						callback(isActive)
						TweenService:Create(BindDisplay, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(25, 25, 35)}):Play()
					end
				end
				
				if not gpe and not isListening and currentMode == "Toggle" then
					local isMatch = false
					if typeof(currentKey) == "EnumItem" then
						if currentKey.EnumType == Enum.KeyCode and input.KeyCode == currentKey then isMatch = true end
						if currentKey.EnumType == Enum.UserInputType and input.UserInputType == currentKey then isMatch = true end
					end
					if isMatch then
						TweenService:Create(BindDisplay, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(25, 25, 35)}):Play()
					end
				end
			end)

			local KeybindAPI = {}
			
			function KeybindAPI:SetKey(newKey)
				currentKey = newKey
				BindText.Text = formatKeyName(newKey)
				onChange(currentKey)
			end
			
			function KeybindAPI:SetMode(newMode)
				if newMode == "Toggle" or newMode == "Hold" then
					currentMode = newMode
					ModeBtn.Text = currentMode
				end
			end
			
			function KeybindAPI:GetState()
				return isActive
			end
			
			function KeybindAPI:GetKey()
				return currentKey
			end

			return KeybindAPI
		end

