		local function SwitchToThisTab()
			if TabBg:GetAttribute("Active") then return end 

			local yPos = TabBg.AbsolutePosition.Y - self.Sidebar.AbsolutePosition.Y
			
			if not self.TabHighlight.Visible then
				self.TabHighlight.Position = UDim2.fromOffset(8, yPos)
				self.TabHighlight.Visible = true
				TweenService:Create(self.TabHighlight, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {BackgroundTransparency = 0.9}):Play()
			else
				TweenService:Create(self.TabHighlight, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
					Position = UDim2.fromOffset(8, yPos)
				}):Play()
			end

			for _, bg in ipairs(self.TabHolder:GetChildren()) do
				if bg:IsA("Frame") and bg ~= TabBg and bg:GetAttribute("Active") == true then
					bg:SetAttribute("Active", false)
					
